# Email alert configuration - required for Gmail alerts
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

# Gmail SMTP server settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465

# Gmail account credentials
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password  # Use app-specific password, not regular password

# Caregiver email (recipient of alerts)
TO_EMAIL=caregiver_email@email.com

# Telegram Bot settings (INSTANT alerts - recommended!)
# Telegram alerts are MUCH FASTER than email
TELEGRAM_BOT_TOKEN=your_bot_token_here

# IMPORTANT: Can be a GROUP ID OR multiple INDIVIDUAL IDs (comma-separated)
# Option 1: Single group (BEST for teams) - negative number
# TELEGRAM_CHAT_ID=-987654321

# Option 2: Multiple team members - comma-separated IDs, no spaces
# TELEGRAM_CHAT_ID=123456789,987654321,555666777

TELEGRAM_CHAT_ID=your_chat_id_here

# Setup Instructions for Gmail:
# 1. Create a Gmail account if you don't have one
# 2. Enable 2-factor authentication: https://support.google.com/accounts/answer/185839
# 3. Create an app-specific password: https://support.google.com/accounts/answer/185833
# 4. Copy your app-specific password above
# 5. Save this file as .env in the project root

# Setup Instructions for Telegram (RECOMMENDED for speed!):
# 1. Open Telegram app
# 2. Search for @BotFather
# 3. Send /start, then /newbot
# 4. Follow prompts - create bot name (e.g., "Patient Alert Bot")
# 5. Copy the token (looks like 123456789:ABCdefGHIjklmnOP...)
# 6. Search for @userinfobot and send /start
# 7. It will show your Chat ID (copy this number)
# 8. Paste both values above